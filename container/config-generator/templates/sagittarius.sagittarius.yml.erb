rails:
  web:
    force_ssl: false
    threads: <%= env('SAGITTARIUS_RAILS_WEB_THREADS', '3') %>
  grpc:
    threads: <%= env('SAGITTARIUS_RAILS_GRPC_THREADS', '6') %>
  log_level: <%= env('SAGITTARIUS_LOG_LEVEL', 'info') %>
  db:
    host: <%= env!('POSTGRES_HOST') %>
    port: <%= env!('POSTGRES_PORT') %>
    pool_size: <%= env('SAGITTARIUS_DB_POOL_SIZE', '8') %>
    encryption:
      primary_key: <%= env!('SAGITTARIUS_DB_ENCRYPTION_PRIMARY_KEY') %>
      deterministic_key: <%= env!('SAGITTARIUS_DB_ENCRYPTION_DETERMINISTIC_KEY') %>
      key_derivation_salt: <%= env!('SAGITTARIUS_DB_ENCRYPTION_KEY_DERIVATION_SALT') %>
  secret_key_base: <%= env!('SAGITTARIUS_RAILS_SECRET_KEY_BASE') %>

velorum:
<% velorum_enabled = env_set?('VELORUM_ENABLED') ? env?('VELORUM_ENABLED') : env('COMPOSE_PROFILES', '').include?('ide_velorum') -%>
  enabled: <%= velorum_enabled %>
<% if velorum_enabled -%>
  host: <%= env!('VELORUM_HOST') %>:<%= env!('VELORUM_PORT') %>
  jwt_secret: <%= env!('VELORUM_JWT_SECRET') %>
<% end -%>
